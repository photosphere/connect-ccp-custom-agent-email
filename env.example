# 后端端口（需与 vite.config.js 中的代理目标一致）
PORT=3001

# AWS 凭证
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# AWS_SESSION_TOKEN=（可选，临时凭证才需要）

# Amazon Connect 配置
CONNECT_INSTANCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CONNECT_REGION=us-east-1
CONNECT_TRANSFER_CONTACT_FLOW_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 多个队列用英文逗号分隔
CONNECT_QUEUE_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SEARCH_LOOKBACK_DAYS=7

# 历史邮件：Amazon Connect 实例 Data storage -> Email messages 配置的 S3 路径
# 形如 s3://<bucket>/connect/<instance-alias>/EmailMessages/
CONNECT_EMAIL_S3_URI=s3://amazon-connect-xxxxxxxxxxxx/connect/xxxx/EmailMessages/
# 可选：S3 桶所在区域（不填则使用 AWS_REGION）
# CONNECT_EMAIL_S3_REGION=us-west-2
